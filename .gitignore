# Local directory for data source plugins and modules
.terraform/

# Lock file containing provider checksums (can be committed in production, but skip for this test harness)
.terraform.lock.hcl

# Local state files (Crucial: State files contain plain-text secrets)
*.tfstate
*.tfstate.*

# Crash logs
crash.log
crash.*.log

# Terraform execution plan files (like the 'tfplan' file you generated)
*tfplan*

# Variable definition files (often contain sensitive operational inputs)
*.tfvars
*.tfvars.json

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# =============================================
# Azure Functions & Python
# =============================================

# Plaintext secrets / credentials (NEVER commit)
keys
local.settings.json

# Python virtual environments
.venv/
azureops-brain/.venv/

# Python bytecode cache
__pycache__/
azureops-brain/__pycache__/

# Azure Functions local package installs
.python_packages/
azureops-brain/.python_packages/

# Azure Functions artifacts
bin/
obj/